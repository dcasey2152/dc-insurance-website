      "permanent": true
    },
    {
      "source": "/college-grove",
      "destination": "/college-grove-insurance",
      "permanent": true
    },
    {
      "source": "/christiana",
      "destination": "/christiana-insurance",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about-us",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/dc-insurance-blog",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/privacy-page",
      "permanent": true
    },
    {
      "source": "/health-insurance-franklin-tn",
      "destination": "/franklin-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-murfreesboro-tn",
      "destination": "/murfreesboro-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-nashville-tn",
      "destination": "/nashville-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-smyrna-tn",
      "destination": "/smyrna-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-nolensville-tn",
      "destination": "/nolensville-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-shelbyville-tn",
      "destination": "/shelbyville-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-chapel-hill-tn",
      "destination": "/chapel-hill-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-college-grove-tn",
      "destination": "/college-grove-insurance",
      "permanent": true
    },
    {
      "source": "/health-insurance-christiana-tn",
      "destination": "/christiana-insurance",
      "permanent": true
    },
    {
      "source": "/outside-of-tennessee",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.dcinsuranceagency.com" }],
      "destination": "https://dcinsuranceagency.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/:path.(jpg|jpeg|png|gif|svg|ico|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
